{
  "name": "mockr",
  "version": "0.1.1",
  "description": "Zero-config OpenAPI mock server — paste a spec, get a running server",
  "bin": { "mockr": "./bin/mockr.js" },
  "main": "./dist/index.js",
  "files": [
    "bin/",
    "dist/",
    "ui-dist/",
    "README.md"
  ],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --outDir dist --clean && npm run build:ui",
    "build:ui": "cd ui && npm run build",
    "dev": "tsx src/cli.ts serve",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@faker-js/faker": "^9.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^4.1.2",
    "commander": "^13.0.0",
    "cors": "^2.8.6",
    "express": "^5.0.1",
    "js-yaml": "^4.1.0",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
